{
  "expo": {
    "name": "SkyView Weather",
    "slug": "weather-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "skyviewweather",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#4A90D9"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4A90D9"
      },
      "package": "com.anonymous.weatherapp"
    },
    "plugins": ["expo-router"]
  }
}
